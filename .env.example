# ===================================
# Google Gemini 2.5-Flash API Configuration
# ===================================
# Get your API key from Google_api_key.txt
GOOGLE_API_KEY=./Google_api_key.txt

# ===================================
# Database & Data Paths
# ===================================
# Vector database path (ChromaDB)
CHROMA_PATH=./data/chroma_store_fulltext

# Training data file
DATA_PATH=./data/data_processed/final_cleaned_data.jsonl

# Queries file (for batch testing)
QUERY_PATH=./src/queries.json

# Model cache directory
MODEL_CACHE_DIR=./src/models_cache

# ===================================
# Search Parameters
# ===================================
# Default number of papers to retrieve
TOP_K=10

# ===================================
# LLM Configuration
# ===================================
# Gemini Model Version (2.5-flash recommended for speed)
GEMINI_MODEL=gemini-2.5-flash

# Generation parameters
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000

# ===================================
# RAG Agent Configuration
# ===================================
# Max tokens for context window
MAX_CONTEXT_TOKENS=2000

# Enable feedback loop for outdated results
ENABLE_FEEDBACK_LOOP=true

# ===================================
# External Search Configuration (arXiv API)
# ===================================
# arXiv API doesn't require authentication (public API)
# Number of papers to fetch from external search
EXTERNAL_SEARCH_NUM_RESULTS=5

# Enable PDF parsing for external papers
PDF_PARSER_ENABLED=true

# ===================================
# Logging & Debug
# ===================================
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug output
DEBUG_MODE=false

# ===================================
# Streamlit Configuration (Optional)
# ===================================
# Streamlit port (if using web UI)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_PORT=8501

# ==========================================
# PyMuPDF Configuration (for PDF extraction)
# ==========================================
# Enable PDF extraction for feedback loop
ENABLE_PDF_EXTRACTION=False

# Cache directory for downloaded PDFs
PDF_CACHE_DIR=./data/pdf_cache
